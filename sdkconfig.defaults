# ---------------------------------------------------------------------------
# sdkconfig.defaults — applied before menuconfig on a clean build.
# Run `idf.py set-target esp32s3` before first build.
# ---------------------------------------------------------------------------

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Flash size — Seeed ESP32-S3 has 8MB flash
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

# FreeRTOS tick rate — arduino-esp32 requires 1000 Hz
CONFIG_FREERTOS_HZ=1000

# FreeRTOS timer task — HAP pair setup M2 runs SRP crypto (Curve25519/Ed25519)
# inside a timer callback; default 2048 bytes overflows during pairing
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=8192

# arduino-esp32: we provide app_main() ourselves and call initArduino() directly
CONFIG_AUTOSTART_ARDUINO=n

# mbedTLS: full certificate bundle for HTTPS (GitHub OTA, MQTT TLS)
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# mbedTLS: PSK cipher suites — required for NetworkClientSecure/ssl_client.cpp
CONFIG_MBEDTLS_PSK_MODES=y

# WDT timeout — matches the 7s set in app_main()
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10

# Pin Arduino event task to core 1 so it doesn't compete with our main loop task.
CONFIG_ARDUINO_EVENT_RUN_CORE1=y
CONFIG_ARDUINO_EVENT_RUNNING_CORE=1

# ---------------------------------------------------------------------------
# HomeKit Accessory Protocol (HAP) — Step 11
# ---------------------------------------------------------------------------

# Bluetooth / NimBLE — required for HAP BLE transport and WAC2 provisioning
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y

# WiFi power save — disable modem sleep to prevent DELBA/frame-drop under load
CONFIG_ESP_WIFI_STA_DISCONNECTED_PM_ENABLE=n

# WiFi A-MPDU — disable TX aggregation to prevent BA session DELBA under CPU load;
# small home-automation payloads don't benefit from throughput gains
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=n
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=16

# HAP port and socket cap — port must not clash with web server (port 80).
# HAP spec requires minimum 8 open sockets for certification; 8+3 internal = 11 used by HAP.
# LWIP_MAX_SOCKETS must cover HAP(11) + web server(4) + WebSocket(4) + MQTT/misc(4) + headroom.
CONFIG_HAP_HTTP_SERVER_PORT=51826
CONFIG_HAP_HTTP_MAX_OPEN_SOCKETS=8

# LWIP tuning — HAP opens many concurrent TCP/UDP connections.
# MAX_ACTIVE_TCP is the PCB pool shared by active AND TIME_WAIT sockets.
# A page load creates ~12 HTTP connections that linger in TIME_WAIT.
# TCP_MSL=10000 → TIME_WAIT = 20s (was 120s), freeing PCBs faster.
CONFIG_LWIP_MAX_SOCKETS=28
CONFIG_LWIP_SO_REUSE=y
CONFIG_LWIP_MAX_ACTIVE_TCP=32
CONFIG_LWIP_MAX_LISTENING_TCP=16
CONFIG_LWIP_TCP_MSL=10000
CONFIG_LWIP_UDP_RECVMBOX_SIZE=10
CONFIG_LWIP_AUTOIP=y
CONFIG_LWIP_AUTOIP_RATE_LIMIT_INTERVAL=60

# HAP platform requirements
CONFIG_MP_BLOB_SUPPORT=y
CONFIG_MBEDTLS_HARDWARE_MPI=y
